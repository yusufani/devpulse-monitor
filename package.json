{
  "name": "devpulse-monitor",
  "displayName": "DevPulse Monitor - CPU RAM GPU Docker Monitor",
  "description": "Real-time GPU, CPU, RAM monitoring with container resource tracking for VS Code",
  "icon": "images/icon.png",
  "version": "1.2.4",
  "publisher": "ANISOFT",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/yusuf-ani/vscode-docker-monitor"
  },
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "gpu",
    "docker",
    "monitor",
    "nvidia",
    "amd",
    "system",
    "vram",
    "cpu",
    "ram",
    "devpulse",
    "process",
    "container",
    "resource"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "DevPulse",
      "properties": {
        "dockerMonitor.refreshInterval": {
          "type": "number",
          "default": 10,
          "minimum": 2,
          "description": "Refresh interval in seconds for sidebar monitoring"
        },
        "dockerMonitor.webviewRefreshInterval": {
          "type": "number",
          "default": 5,
          "minimum": 2,
          "description": "Refresh interval in seconds for webview panel"
        },
        "dockerMonitor.gpuMonitoring": {
          "type": "boolean",
          "default": true,
          "description": "Enable GPU monitoring"
        },
        "dockerMonitor.dockerBinary": {
          "type": "string",
          "default": "",
          "description": "Custom path to docker binary (auto-detected if empty)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dockerMonitor",
          "title": "DevPulse",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "dockerMonitor": [
        {
          "type": "webview",
          "id": "dockerServices",
          "name": "Container Resources"
        },
        {
          "id": "gpuMonitor",
          "name": "System Monitor"
        }
      ]
    },
    "commands": [
      {
        "command": "dockerServices.refresh",
        "title": "Refresh Container Resources",
        "icon": "$(refresh)"
      },
      {
        "command": "gpuMonitor.refresh",
        "title": "Refresh System Monitor",
        "icon": "$(refresh)"
      },
      {
        "command": "gpuMonitor.show",
        "title": "Open GPU Monitor",
        "icon": "$(window)"
      },
      {
        "command": "gpuMonitor.killProcess",
        "title": "Kill Process",
        "icon": "$(close)"
      },
      {
        "command": "gpuMonitor.stopContainer",
        "title": "Stop Container",
        "icon": "$(debug-stop)"
      },
      {
        "command": "gpuMonitor.killContainer",
        "title": "Force Kill Container",
        "icon": "$(trash)"
      },
      {
        "command": "gpuMonitor.restartContainer",
        "title": "Restart Container",
        "icon": "$(debug-restart)"
      },
      {
        "command": "gpuMonitor.showContainerLogs",
        "title": "Show Container Logs",
        "icon": "$(output)"
      },
      {
        "command": "gpuMonitor.execContainer",
        "title": "Exec into Container",
        "icon": "$(terminal)"
      },
      {
        "command": "gpuMonitor.attachContainer",
        "title": "Attach to Container",
        "icon": "$(plug)"
      },
      {
        "command": "gpuMonitor.showTopConsumers",
        "title": "DevPulse: Show Top GPU Consumers"
      },
      {
        "command": "gpuMonitor.findContainer",
        "title": "DevPulse: Find Container"
      },
      {
        "command": "gpuMonitor.copyContainerId",
        "title": "Copy Container ID"
      },
      {
        "command": "gpuMonitor.copyContainerName",
        "title": "Copy Container Name"
      },
      {
        "command": "gpuMonitor.copyContainerImage",
        "title": "Copy Container Image"
      },
      {
        "command": "gpuMonitor.openPort",
        "title": "Open Port in Browser",
        "icon": "$(globe)"
      },
      {
        "command": "gpuMonitor.showEnvVars",
        "title": "Show Environment Variables",
        "icon": "$(symbol-variable)"
      },
      {
        "command": "gpuMonitor.showVolumes",
        "title": "Show Volume Mounts",
        "icon": "$(folder-library)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dockerServices.refresh",
          "when": "view == dockerServices",
          "group": "navigation"
        },
        {
          "command": "gpuMonitor.show",
          "when": "view == gpuMonitor",
          "group": "navigation"
        },
        {
          "command": "gpuMonitor.refresh",
          "when": "view == gpuMonitor",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "gpuMonitor.killProcess",
          "when": "view == gpuMonitor && viewItem == gpuProcess",
          "group": "inline"
        },
        {
          "command": "gpuMonitor.stopContainer",
          "when": "view == gpuMonitor && viewItem == gpuContainer",
          "group": "inline"
        },
        {
          "command": "gpuMonitor.restartContainer",
          "when": "view == gpuMonitor && viewItem == gpuContainer",
          "group": "inline"
        },
        {
          "command": "gpuMonitor.killContainer",
          "when": "view == gpuMonitor && viewItem == gpuContainer"
        },
        {
          "command": "gpuMonitor.showContainerLogs",
          "when": "view == gpuMonitor && viewItem == gpuContainer"
        },
        {
          "command": "gpuMonitor.execContainer",
          "when": "view == gpuMonitor && viewItem == gpuContainer"
        },
        {
          "command": "gpuMonitor.attachContainer",
          "when": "view == gpuMonitor && viewItem == gpuContainer"
        },
        {
          "command": "gpuMonitor.openPort",
          "when": "view == gpuMonitor && viewItem == gpuContainer"
        },
        {
          "command": "gpuMonitor.showEnvVars",
          "when": "view == gpuMonitor && viewItem == gpuContainer"
        },
        {
          "command": "gpuMonitor.showVolumes",
          "when": "view == gpuMonitor && viewItem == gpuContainer"
        },
        {
          "command": "gpuMonitor.copyContainerId",
          "when": "view == gpuMonitor && viewItem == gpuContainer"
        },
        {
          "command": "gpuMonitor.copyContainerName",
          "when": "view == gpuMonitor && viewItem == gpuContainer"
        },
        {
          "command": "gpuMonitor.copyContainerImage",
          "when": "view == gpuMonitor && viewItem == gpuContainer"
        }
      ]
    },
    "keybindings": [
      {
        "command": "gpuMonitor.show",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "gpuMonitor.findContainer",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      },
      {
        "command": "gpuMonitor.showTopConsumers",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "package": "npm run compile && mkdir -p dist && npx @vscode/vsce package --no-dependencies -o dist/",
    "publish": "npx @vscode/vsce publish --no-dependencies",
    "publish:ovsx": "npx ovsx publish *.vsix",
    "precommit": "npm run lint && npm run typecheck"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0"
  }
}
